# ─── Excel Provider — Environment Configuration ───────────────────────────────
# cp .env.example .env

# IP/hostname của HDOS server (reachable từ Docker containers này)
# Dùng để kết nối: provider-bridge (5400), request-api (5000), ingestion-api (5100)
#
# Ví dụ:
#   HDOS_HOST=192.168.1.100    ← LAN IP của server chạy HDOS
#   HDOS_HOST=10.0.0.5         ← VPN / cloud IP
#
# ⚠ KHÔNG dùng "localhost" — Docker containers không thể reach localhost của host
HDOS_HOST=192.168.1.100

# ─── Xác thực provider (chọn 1 trong 2 cách) ─────────────────────────────────

# Cách A — Bootstrap Token (khuyến nghị)
# Lấy từ HDOS Admin UI → chọn excel-provider → tab Credentials → "Tạo Bootstrap Token"
# Provider sẽ tự fetch ClientSecret từ HDOS khi khởi động.
# Sau khi đã fetch thành công, token vẫn còn dùng được cho lần restart tiếp theo.
HDOS_BOOTSTRAP_TOKEN=

# Cách B — Direct Secret (thay thế, nếu không dùng bootstrap)
# Đặt secret khớp với HDOS Admin UI → Credentials tab → "Đặt secret cụ thể"
# Nếu để trống, provider sẽ dùng HDOS_BOOTSTRAP_TOKEN ở trên.
# EXCEL_PROVIDER_SECRET=
