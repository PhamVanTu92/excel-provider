<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <RootNamespace>ReportingPlatform.ExcelProvider</RootNamespace>
    <AssemblyName>ReportingPlatform.Excel.Provider</AssemblyName>
    <!-- Microsoft.NET.Sdk.Web already provides ASP.NET Core, Hosting, Http, Logging, Json -->
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Grpc.Net.Client"   Version="2.65.0" />
    <PackageReference Include="Google.Protobuf"   Version="3.29.3" />
    <PackageReference Include="Grpc.Tools"        Version="2.65.0" PrivateAssets="All" />
    <PackageReference Include="Npgsql"            Version="9.0.3" />
  </ItemGroup>

  <ItemGroup>
    <Protobuf Include="..\proto\provider.proto" GrpcServices="Client" />
  </ItemGroup>
</Project>
